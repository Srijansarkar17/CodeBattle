# ==============================================================================
# CodeBattle Backend - Environment Variables
# Copy this file to .env and fill in your actual values
# ==============================================================================

# Application
APP_NAME=CodeBattle
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://codebattle:codebattle_password@localhost:5432/codebattle_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
FRONTEND_URL=http://localhost:3000

# Matchmaking
MATCHMAKING_RATING_RANGE=100
MATCHMAKING_TIMEOUT_SECONDS=60
MATCHMAKING_POLL_INTERVAL=2
